{
  "name": "Progress",
  "type": "object",
  "properties": {
    "user_email": {
      "type": "string"
    },
    "course_id": {
      "type": "string"
    },
    "completed_lessons": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "progress_percent": {
      "type": "number",
      "default": 0
    },
    "quiz_scores": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "quiz_id": {
            "type": "string"
          },
          "score": {
            "type": "number"
          },
          "date": {
            "type": "string"
          }
        }
      }
    },
    "time_spent_minutes": {
      "type": "number",
      "default": 0
    },
    "last_accessed": {
      "type": "string",
      "format": "date-time"
    },
    "strengths": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "weaknesses": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "required": [
    "user_email",
    "course_id"
  ]
}
